RewriteEngine On
RewriteBase /po/admin/

# External redirect: remove .php extension
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/po/admin/([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Internal rewrite: map clean URLs to .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [NC,L]
