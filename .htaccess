RewriteEngine On
# RewriteBase auto-detected by Apache

# External redirect: remove .php extension if present in URL (GET requests only)
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Specific rule for post slug
RewriteRule ^post/([^/]+)/?$ post.php?slug=$1 [NC,L]

# Internal rewrite: map clean URLs to .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [NC,L]
